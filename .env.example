VITE_SUPABASE_URL=https://xulnxwwwjpvgsaqnsllo.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sign in with Apple — not used by the native signInWithIdToken flow (that
# path only needs the bundle ID allow-listed in the Supabase dashboard), but
# kept here for the web OAuth fallback / future use. Fill these in after
# generating a Services ID + key in the Apple Developer portal.
VITE_APPLE_SERVICES_ID=
VITE_APPLE_TEAM_ID=

# Playwright E2E — required for test user provisioning
# Get from Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: override test user password (default is a stable internal value)
PLAYWRIGHT_TEST_PASSWORD=
